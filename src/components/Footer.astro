---
/**
 * Site footer: tagline, section links, legal links, social.
 * Legal pages exist in Italian only for now; the /en/ routes show the
 * Italian text with a notice (see src/pages/[lang]/legale/).
 */
import { localePath, useTranslations, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();

const sections = [
  { href: localePath(lang, 'catalogo/'), label: t('foot_catalog') },
  { href: localePath(lang, 'chi-siamo/'), label: t('foot_about') },
  { href: localePath(lang, 'contatti/'), label: t('foot_contact') },
];
const legal = [
  { href: localePath(lang, 'legale/privacy/'), label: t('foot_privacy') },
  { href: localePath(lang, 'legale/cookie-policy/'), label: t('foot_cookies') },
  { href: localePath(lang, 'legale/termini-di-vendita/'), label: t('foot_terms') },
  { href: localePath(lang, 'legale/recesso/'), label: t('foot_withdrawal') },
  { href: localePath(lang, 'legale/spedizioni-e-resi/'), label: t('foot_shipping') },
];
---

<footer class="site-footer">
  <div class="container-x inner">
    <div class="brand">
      <a href={localePath(lang)} class="serif wordmark">Nava</a>
      <p class="text-muted tag">{t('foot_tag')}</p>
      <a href="mailto:info@navaeditore.com" class="link-inline mail">info@navaeditore.com</a>
    </div>

    <nav aria-label={t('aria_footer_nav')} class="cols">
      <ul role="list">
        {sections.map((l) => <li><a class="foot-link" href={l.href}>{l.label}</a></li>)}
      </ul>
      <ul role="list">
        {legal.map((l) => <li><a class="foot-link" href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>

    <div class="social" aria-label="Social">
      <a href="https://instagram.com/" rel="noopener" aria-label="Instagram" class="icon-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
      </a>
      <a href="https://x.com/" rel="noopener" aria-label="X" class="icon-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 3h3l-7 8 8.2 10h-6.4l-5-6.1L8 21H5l7.4-8.5L4.5 3h6.6l4.5 5.6L17.5 3Zm-1 16h1.7L8 4.8H6.2L16.5 19Z"/></svg>
      </a>
    </div>
  </div>

  <p class="container-x colophon text-muted">
    © {year} Nava Edizioni — [TODO: ragione sociale] · {t('foot_vat')} · {t('foot_rights')}
  </p>
</footer>

<style>
  .site-footer { border-top: 1px solid var(--line); padding: var(--space-8) 0 var(--space-6); }
  .inner {
    display: flex; flex-direction: column; gap: var(--space-6);
  }
  @media (min-width: 768px) {
    .inner { flex-direction: row; align-items: flex-start; justify-content: space-between; }
  }
  .wordmark { font-size: 1.5rem; }
  .tag { font-size: var(--text-sm); margin-top: var(--space-2); max-width: 34ch; }
  .mail { display: inline-block; margin-top: var(--space-3); font-size: var(--text-sm); }

  .cols { display: flex; gap: var(--space-8); }
  .cols ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-2); }
  .foot-link {
    font-size: var(--text-sm); color: var(--muted); padding: 0.15rem 0; display: inline-block;
    transition: color var(--speed) var(--ease);
  }
  .foot-link:hover { color: var(--ink); }

  .social { display: flex; gap: 1.25rem; }
  .icon-link {
    color: var(--muted); transition: color var(--speed) var(--ease);
    display: inline-flex; padding: 0.5rem; margin: -0.5rem;
  }
  .icon-link:hover { color: var(--ink); }

  .colophon { font-size: 0.75rem; margin-top: var(--space-7); }
</style>
