---
/**
 * Category page — one indexable static page per category × language
 * (/it/categoria/<slug>/, /en/categoria/<slug>/), each with its own
 * title/description. The catalog's client-side filter still exists for
 * instant browsing; these pages are the crawlable entry points.
 */
import Base from '../../../layouts/Base.astro';
import BookCard from '../../../components/BookCard.astro';
import CategoryIcon from '../../../components/CategoryIcon.astro';
import { CATEGORIES, byCategory } from '../../../data/books';
import { LANGUAGES, localePath, useTranslations, type Lang } from '../../../i18n';

export function getStaticPaths() {
  return LANGUAGES.flatMap((lang) =>
    CATEGORIES.map((category) => ({ params: { lang, slug: category.slug }, props: { category } }))
  );
}

const lang = Astro.params.lang as Lang;
const { category } = Astro.props as { category: (typeof CATEGORIES)[number] };
const t = useTranslations(lang);

const name = category[lang];
const description = category.desc[lang];
const items = byCategory(category.slug).sort((a, b) => b.year - a.year);
const others = CATEGORIES.filter((c) => c.slug !== category.slug);
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${name} — Nava`,
    description,
    url: pageUrl,
    inLanguage: lang,
    isPartOf: { '@type': 'WebSite', name: 'Nava', url: 'https://navaeditore.com/' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: t('nav_home'), item: new URL(localePath(lang), Astro.site).href },
      { '@type': 'ListItem', position: 2, name: t('nav_catalog'), item: new URL(localePath(lang, 'catalogo/'), Astro.site).href },
      { '@type': 'ListItem', position: 3, name, item: pageUrl },
    ],
  },
];
---

<Base
  {lang}
  title={`${name} — ${t('catpg_title')} Nava`}
  description={description}
  active="catalog"
  {jsonLd}
>
  <div class="container-x page">
    <nav aria-label={t('aria_breadcrumb')} class="breadcrumb">
      <a href={localePath(lang, 'catalogo/')} class="back link-inline">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M15 6l-6 6 6 6" /></svg>
        {t('bk_back')}
      </a>
    </nav>

    <header class="page-head">
      <span class="text-accent icon"><CategoryIcon slug={category.slug} size={36} /></span>
      <h1 class="serif page-title">{name}</h1>
      <p class="text-muted page-sub">{description}</p>
      <p class="smallcaps text-muted count">{items.length} {t('results_word')}</p>
    </header>

    <section aria-label={t('cat_all_titles')}>
      <div class="grid">
        {items.map((product, i) => <BookCard {product} {lang} eager={i < 3} />)}
      </div>
    </section>

    <section class="others">
      <h2 class="smallcaps text-muted others-h">{t('cat_other')}</h2>
      <ul class="chips" role="list">
        {others.map((other) => (
          <li>
            <a class="chip" href={localePath(lang, `categoria/${other.slug}/`)}>{other[lang]}</a>
          </li>
        ))}
        <li><a class="chip chip-all" href={localePath(lang, 'catalogo/')}>{t('filter_all')}</a></li>
      </ul>
    </section>
  </div>
</Base>

<style>
  .page { padding-top: var(--space-7); padding-bottom: var(--space-8); }
  .breadcrumb { margin-bottom: var(--space-6); }
  .back { display: inline-flex; align-items: center; gap: 0.25rem; font-size: var(--text-sm); border-bottom: 0; }

  .page-head { margin-bottom: var(--space-7); max-width: 58ch; }
  .icon { display: inline-block; }
  .page-title { font-size: var(--text-5xl); margin-top: var(--space-3); }
  .page-sub { margin-top: var(--space-4); font-size: var(--text-lg); }
  .count { font-size: var(--text-sm); margin-top: var(--space-3); }

  .grid { display: grid; grid-template-columns: 1fr; gap: 3.5rem 2rem; }
  @media (min-width: 640px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .grid { grid-template-columns: repeat(3, 1fr); } }

  .others { margin-top: var(--space-9); border-top: 1px solid var(--line); padding-top: var(--space-6); }
  .others-h { font-size: var(--text-sm); margin-bottom: var(--space-4); }
  .chips { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: var(--space-3); }
  .chip {
    display: inline-flex; align-items: center; min-height: 44px;
    padding: 0.45rem 1rem; border: 1px solid var(--line); border-radius: var(--radius-full);
    font-size: var(--text-sm); color: var(--muted);
    transition: color var(--speed) var(--ease), border-color var(--speed) var(--ease),
                background var(--speed) var(--ease);
  }
  .chip:hover { color: var(--ink); border-color: var(--ink); background: var(--surface); }
  .chip-all { color: var(--accent-text); border-color: var(--accent-text); }
  .chip-all:hover { color: var(--on-accent); background: var(--accent); border-color: var(--accent); }
</style>
