---
/**
 * Layout for legal pages. Content is Italian-only for now: the /en/
 * routes render the same Italian text with a notice on top.
 * Placeholders like [TODO: ragione sociale] must be filled before
 * launch — this is a structural template, NOT legal advice.
 */
import Base from './Base.astro';
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  /** dd/mm/yyyy or [TODO]. */
  updated?: string;
}

const { lang, title, description, updated = '[TODO: data]' } = Astro.props;
const t = useTranslations(lang);
---

<Base {lang} title={`${title} — Nava`} {description}>
  <div class="container-x page">
    {lang !== 'it' && (
      <p class="notice" role="note">{t('legal_en_note')}</p>
    )}
    <header class="head">
      <p class="smallcaps text-muted kicker">Legale</p>
      <h1 class="serif title">{title}</h1>
      <p class="text-muted updated">{t('legal_updated')}: {updated}</p>
    </header>
    <div class="prose body">
      <slot />
    </div>
  </div>
</Base>

<style>
  .page { padding-top: var(--space-8); padding-bottom: var(--space-9); max-width: 820px; }
  .notice {
    border: 1px solid var(--line); border-left: 3px solid var(--accent);
    border-radius: var(--radius-sm); background: var(--surface);
    padding: var(--space-4) var(--space-5); margin-bottom: var(--space-6);
    font-size: var(--text-sm);
  }
  .kicker { font-size: var(--text-sm); margin-bottom: var(--space-3); }
  .title { font-size: var(--text-4xl); }
  .updated { font-size: var(--text-sm); margin-top: var(--space-3); }
  .head { margin-bottom: var(--space-7); }
  .body :global(h2) { font-size: var(--text-2xl); margin: var(--space-7) 0 var(--space-3); }
  .body :global(ul) { max-width: 65ch; padding-left: 1.2rem; }
  .body :global(li) { margin-bottom: 0.4em; }
</style>
